{
  "compilerOptions": {
    // 目标 ES2022：使用顶层 await / class 字段等现代特性
    "target": "ES2022",
    // 模块按需解析，交由 Bundler（Vite）处理
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    // 数组/对象索引访问返回 T 而非 T | undefined 的反模式，这里要求显式处理 undefined
    "noUncheckedIndexedAccess": true,
    // 可选属性必须严格区分 undefined，避免误传
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
