{
  "name": "yila-web-control",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace packages/yila-core run build && npm --workspace apps/web run build",
    "test": "npm --workspace packages/yila-core run test"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.19"
  }
}
